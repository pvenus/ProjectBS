                                                                   "choiceName":  "defend_jihan_and_child",
                                                                   "choiceId":  "choice.act1.chapter01.episode03_1.jihan_join.defend_jihan_and_child",
                                                                   "legacyChoiceId":  "episode.act1.chapter01.03_1.choice.defend_jihan_and_child.1",
                                                                   "sourceChoiceText":  "지한과 아이를 지키며 추격자들을 막아낸다.",
                                                                   "rewardDirection":  [
                                                                                           "gold_battle_reward"
                                                                                       ]
