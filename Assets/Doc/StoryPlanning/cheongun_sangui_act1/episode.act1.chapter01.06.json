                                               "nextPopupId":  "node.act1.chapter01.episode06.organized_raider_signs",
                                               "choices":  [
                                                               {
                                                                   "choiceName":  "attack_bandit_fort",
                                                                   "choiceId":  "choice.act1.chapter01.episode06.assault_decision.attack_bandit_fort",
                                                                   "legacyChoiceId":  "episode.act1.chapter01.06.choice.attack_bandit_fort.1",
                                                                   "sourceChoiceText":  "산채를 공격한다.",
