    {
      "nodeId": "stage.story.hard.004.rescue",
      "body": "무너진 갱도 사이를 기어가 갇힌 광부를 찾아냈다.\n광부는 탈출하며 갱도 지도를 머릿속에 새겨주었다.",
      "rewardType": "exp",
      "rewardValue": 100,
