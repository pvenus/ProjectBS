    {
      "nodeId": "stage.story.hard.013.fire",
      "body": "입구 바깥에 작은 불을 피우고 얼어붙은 손을 녹였다.\n잠시나마 몸에 온기가 돌아오며 통증이 가라앉았다.",
      "rewardType": "heal",
      "rewardValue": 45,
      "nextNodeId": "stage.story.hard.013.end"
