      "nextNodeId": "stage.story.easy.002.end"
    },
    {
      "nodeId": "stage.story.easy.002.eat",
      "body": "막 씻은 과일을 한입 베어 물었다.\n상큼한 단맛이 입안에 퍼지며 기운이 돌아왔다.",
      "rewardType": "heal",
