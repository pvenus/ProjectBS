  eventId: event:rainy_graveyard:popup
  title: "\uBE44 \uC624\uB294 \uBB18\uC9C0"
  body: "\uBE44\uAC00 \uC5B5\uC218\uAC19\uC774 \uC3DF\uC544\uC9C0\uB294 \uBC24.\n\uAE38\uC744
    \uC783\uC740 \uB2F9\uC2E0\uB4E4\uC740 \uC624\uB798\uB41C \uBB18\uC9C0\uC5D0 \uB3C4\uCC29\uD588\uB2E4.\n\uBB34\uB108\uC9C4
    \uBE44\uC11D\uB4E4 \uC0AC\uC774\uB85C \uD76C\uBBF8\uD55C \uBD88\uBE5B \uD558\uB098\uAC00
    \uD754\uB4E4\uB9AC\uACE0 \uC788\uC5C8\uB2E4."
  mainImage: {fileID: -4501457855696675630, guid: 30c7261cd17a9459795f113aa8becce9, type: 3}
  icon: {fileID: -4501457855696675630, guid: 30c7261cd17a9459795f113aa8becce9, type: 3}
  choices:
  - choiceId: event:rainy_graveyard:popup:choice:1
    label: "\uBD88\uBE5B\uC744 \uB530\uB77C\uAC04\uB2E4"
    description: 
    resultText: "\uBD88\uBE5B\uC758 \uC815\uCCB4\uB294 \uBB34\uB364\uC744 \uB3CC\uBCF4\uB294
      \uB178\uC778\uC774\uC5C8\uB2E4.\n\uB178\uC778\uC740 \uB9D0\uC5C6\uC774 \uB530\uB73B\uD55C
      \uC218\uD504\uB97C \uB0B4\uC5B4\uC8FC\uC5C8\uB2E4."
