  choices:
  - choiceId: event:broken_automaton:popup:choice:1
    label: "\uB3D9\uB825\uC744 \uBCF5\uAD6C\uD574\uBCF8\uB2E4"
    description: 
    resultText: "\uC790\uB3D9\uC778\uD615\uC740 \uCC9C\uCC9C\uD788 \uBAB8\uC744 \uC77C\uC73C\uCF30\uB2E4.\n\n\uC7A0\uC2DC
      \uB2F9\uC2E0\uC744 \uBC14\uB77C\uBCF4\uB358 \uC778\uD615\uC740 \uC791\uC740
      \uBCF4\uAD00\uD568 \uD558\uB098\uB97C \uAC74\uB124\uACE0 \uC0AC\uB77C\uC84C\uB2E4."
