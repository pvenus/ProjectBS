{
  "documentId": "character_stat.score_200.balanced.v3",
  "titleKo": "Score 200 밸런스형 캐릭터 스탯",
  "targetScore": 200,
  "archetype": "balanced",
  "growthType": "Balanced",
  "characterType": "Player",
  "designIntentKo": "CharacterStatGuild.md의 Total Score 모델을 기준으로 작성한 Score 200 밸런스형 캐릭터 스탯 세트다. 실제 스탯을 먼저 정하지 않고, 밸런스형 Multiple과 스탯별 성장 정책을 먼저 정의한 뒤 계산한다.",
  "calculationModel": {
    "sourceGuide": "Assets/character_concepts/game_prompt_guide/character/CharacterStatGuild.md",
    "standardScore": 100,
    "targetScore": 200,
    "scoreRatio": 2,
    "typeMultiples": {
      "attack": 1,
      "defense": 1,
      "utility": 1
    },
    "typeMultipleBasisKo": "밸런스형은 공격, 방어, 유틸 어느 한 축도 의도적으로 강화하거나 약화하지 않으므로 세 축의 Multiple을 모두 1.0으로 둔다.",
    "statMultiples": [
      {
        "statType": "Attack",
        "axis": "attack",
        "multiple": 1,
        "growthPolicy": "DefaultGrowth",
        "applyScoreRatio": true
      },
      {
        "statType": "MaxHp",
        "axis": "defense",
        "multiple": 1,
        "growthPolicy": "DefaultGrowth",
        "applyScoreRatio": true
      },
      {
        "statType": "HpRegen",
        "axis": "utility",
        "multiple": 1,
        "growthPolicy": "DefaultGrowth",
        "applyScoreRatio": true
      },
      {
        "statType": "Defense",
        "axis": "defense",
        "multiple": 1,
        "growthPolicy": "SpecialGrowth",
        "applyScoreRatio": false
      },
      {
        "statType": "CritChance",
        "axis": "attack",
        "multiple": 1,
        "growthPolicy": "SpecialGrowth",
        "applyScoreRatio": false
      },
      {
        "statType": "CritDamage",
        "axis": "attack",
        "multiple": 1,
        "growthPolicy": "SpecialGrowth",
        "applyScoreRatio": false
      },
      {
        "statType": "AttackSpeed",
        "axis": "attack",
        "multiple": 1,
        "growthPolicy": "SpecialGrowth",
        "applyScoreRatio": false
      },
      {
        "statType": "MoveSpeed",
        "axis": "utility",
        "multiple": 1,
        "growthPolicy": "SpecialGrowth",
        "applyScoreRatio": false
      }
    ],
    "formula": {
      "defaultGrowthKo": "value = score100Value * scoreRatio * typeMultiple(axis) * statMultiple",
      "specialGrowthKo": "value = score100Value * statMultiple"
    }
  },
