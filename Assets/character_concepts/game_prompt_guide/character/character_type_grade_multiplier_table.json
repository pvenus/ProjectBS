  "calculationFormula": {
    "axisScoreKo": "axisScore = score * axisMultiple(type, axis)",
    "defaultGrowthStatKo": "value = score100Value * realizedGrowthTarget(grade) * axisMultiple(type, axis) * statMultiple(type, stat)",
    "specialGrowthStatKo": "value = score100Value * gradeStatMultiple(grade) * statMultiple(type, stat)",
    "monsterScoreKo": "monsterScore = playerGradeScore * playerScorePercent / 100",
    "taggedAxisScoreKo": "taggedAxisScore = score * typeAxisMultiple * tagAxisMultiple * typeTagAxisOverride",
    "taggedDefaultGrowthStatKo": "value = score100Value * realizedGrowthTarget(grade) * typeAxisMultiple * tagAxisMultiple * typeTagAxisOverride * typeStatMultiple * tagStatMultiple * typeTagStatOverride",
    "taggedSpecialGrowthStatKo": "value = score100Value * gradeStatMultiple(grade) * typeStatMultiple * tagStatMultiple * typeTagStatOverride"
  },
  "tagSystem": {
    "purposeKo": "타입이 전투 역할을 정의한다면, 태그는 종족/군집/문화권의 고유 체질을 정의한다. 최종 스탯은 타입과 태그의 조합으로 결정된다.",
    "applicationOrder": [
      "1. Select Total Score and Grade",
      "2. Apply Type axis/stat multiples",
      "3. Apply Grade growth target",
      "4. Apply Tag base multiples",
      "5. Apply Type+Tag override multiples",
      "6. Clamp special stat growth if needed"
    ],
    "formula": {
      "finalAxisMultipleKo": "finalAxisMultiple = typeAxisMultiple * tagAxisMultiple * typeTagAxisOverride",
      "defaultGrowthStatKo": "value = score100Value * realizedGrowthTarget(grade) * finalAxisMultiple * typeStatMultiple * tagStatMultiple * typeTagStatOverride",
      "specialGrowthStatKo": "value = score100Value * gradeStatMultiple(grade) * typeStatMultiple * tagStatMultiple * typeTagStatOverride",
      "clampedValueKo": "value = clamp(value, statMin, statMax) when a clamp is defined"
    },
